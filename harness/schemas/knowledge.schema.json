    "created_at": {"minLength": 1, "type": "string"},
    "decisions": {"items": {"type": "string"}, "type": "array"},
    "errors": {"items": {"type": "string"}, "type": "array"},
    "id": {"minLength": 1, "type": "string"},
    "patterns": {"items": {"type": "string"}, "type": "array"},
    "run_id": {"minLength": 1, "type": "string"},
    "solutions": {"items": {"type": "string"}, "type": "array"},
    "summary": {"minLength": 1, "type": "string"},
    "tags": {"items": {"type": "string"}, "type": "array"}
